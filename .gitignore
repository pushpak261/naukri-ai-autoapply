# Data (runtime artifacts — never commit these)
backend/data/sessions/
backend/data/resumes/
backend/data/*.db
backend/data/*.db-*
backend/data/naukri_agent_backup_*.db
backend/data/logs/
backend/data/match_cache.json
backend/data/qa_cache.json
backend/src/data/

# Personal data — your resume contains PII and shouldn't be pushed to a
# remote repo even though the agent needs a local copy to run.
backend/resume.pdf
backend/*.resume.pdf
backend/resume_profile.json
backend/resume_profile.json.enc
backend/resume.pdf.enc
backend/resume_key.txt

