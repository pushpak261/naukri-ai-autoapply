# Naukri.com Credentials
NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_password_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail OTP Automatic Retrieval Credentials (Optional)
GMAIL_OTP_EMAIL=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_digit_app_password
NAUKRI_MOBILE_NUMBER=your_mobile_number_here
NAUKRI_USE_OTP_LOGIN=False

# Resume decryption for local setup (optional — or use resume_key.txt)
# RESUME_KEY=

# Email Alerts (Optional — defaults to GMAIL_OTP_EMAIL as recipient)
ALERT_EMAIL_TO=


